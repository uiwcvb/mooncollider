name = "bubuki/mooncollider"

version = "0.1.0"

readme = "README.mbt.md"

repository = "https://gitlink.org.cn/bubuki/mooncollider"

license = "Apache-2.0"

keywords = [ "physics", "collision", "game", "2d", "gamedev" ]

preferred_target = "wasm-gc"

description = "2D game physics and collision detection library for MoonBit"
